{
  "name": "sonicinspired-theme",
  "displayName": "Sonic Inspired Theme",
  "description": "Unofficial fan themes for VS Code / Cursor: Sonic, Tails, and Knuckles (Dark + Light each), plus character file icons. Free, non-profit, not affiliated with SEGA.",
  "version": "1.2.1",
  "publisher": "AndreLuizJPoles",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "icon.png",
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreLuizJPoles/SonicTheme.git"
  },
  "bugs": {
    "url": "https://github.com/AndreLuizJPoles/SonicTheme/issues"
  },
  "homepage": "https://github.com/AndreLuizJPoles/SonicTheme#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "icon-theme",
    "dark",
    "light",
    "sonic",
    "tails",
    "knuckles",
    "sonic-inspired",
    "fan-theme"
  ],
  "activationEvents": [
    "onCommand:sonic-inspired.chooseMode",
    "onCommand:sonic-inspired.darkColorsOnly",
    "onCommand:sonic-inspired.lightColorsOnly",
    "onCommand:sonic-inspired.tailsDarkColorsOnly",
    "onCommand:sonic-inspired.tailsLightColorsOnly",
    "onCommand:sonic-inspired.knucklesDarkColorsOnly",
    "onCommand:sonic-inspired.knucklesLightColorsOnly"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sonic-inspired.chooseMode",
        "title": "Choose Theme…",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.darkColorsOnly",
        "title": "Sonic Dark",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.lightColorsOnly",
        "title": "Sonic Light",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.tailsDarkColorsOnly",
        "title": "Tails Dark",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.tailsLightColorsOnly",
        "title": "Tails Light",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.knucklesDarkColorsOnly",
        "title": "Knuckles Dark",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.knucklesLightColorsOnly",
        "title": "Knuckles Light",
        "category": "Sonic-Inspired"
      }
    ],
    "themes": [
      {
        "label": "Sonic-Inspired Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/sonic-dark-color-theme.json"
      },
      {
        "label": "Sonic-Inspired Light",
        "uiTheme": "vs",
        "path": "./themes/sonic-light-color-theme.json"
      },
      {
        "label": "Sonic-Inspired Tails Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/tails-dark-color-theme.json"
      },
      {
        "label": "Sonic-Inspired Tails Light",
        "uiTheme": "vs",
        "path": "./themes/tails-light-color-theme.json"
      },
      {
        "label": "Sonic-Inspired Knuckles Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/knuckles-dark-color-theme.json"
      },
      {
        "label": "Sonic-Inspired Knuckles Light",
        "uiTheme": "vs",
        "path": "./themes/knuckles-light-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "sonic-inspired-icons",
        "label": "Sonic-Inspired Icons",
        "path": "./icons/sonic-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "icons:transparent": "node scripts/make-icons-transparent.mjs",
    "package": "vsce package",
    "package:marketplace": "node scripts/package-marketplace.mjs"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "sharp": "^0.33.5"
  }
}
