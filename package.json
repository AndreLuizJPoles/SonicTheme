{
  "name": "sonic-inspired-theme",
  "displayName": "Sonic-Inspired Theme",
  "description": "Unofficial Sonic the Hedgehog–inspired VS Code theme — four Command Palette modes (Dark/Light × with or without character icons). Free fan project, non-profit, not affiliated with SEGA.",
  "version": "1.0.0",
  "publisher": "AndreLuizJPoles",
  "license": "SEE LICENSE IN LICENSE",
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreLuizJPoles/SonicTheme.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "sonic",
    "sonic-inspired",
    "fan-theme",
    "theme",
    "color-theme",
    "icon-theme",
    "dark",
    "light"
  ],
  "activationEvents": [
    "onCommand:sonic-inspired.chooseMode",
    "onCommand:sonic-inspired.darkWithIcons",
    "onCommand:sonic-inspired.lightWithIcons",
    "onCommand:sonic-inspired.darkColorsOnly",
    "onCommand:sonic-inspired.lightColorsOnly"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sonic-inspired.chooseMode",
        "title": "Choose Mode…",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.darkWithIcons",
        "title": "Full Dark (colors + icons)",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.lightWithIcons",
        "title": "Full Light (colors + icons)",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.darkColorsOnly",
        "title": "Dark colors only",
        "category": "Sonic-Inspired"
      },
      {
        "command": "sonic-inspired.lightColorsOnly",
        "title": "Light colors only",
        "category": "Sonic-Inspired"
      }
    ],
    "themes": [
      {
        "label": "Sonic-Inspired Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/sonic-dark-color-theme.json"
      },
      {
        "label": "Sonic-Inspired Light",
        "uiTheme": "vs",
        "path": "./themes/sonic-light-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "sonic-inspired-icons",
        "label": "Sonic-Inspired Icons",
        "path": "./icons/sonic-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "icons:transparent": "node scripts/make-icons-transparent.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "sharp": "^0.33.5"
  }
}
