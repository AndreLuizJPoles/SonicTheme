{
  "name": "sonic-inspired-theme",
  "displayName": "Sonic-Inspired Theme",
  "description": "Tema visual não oficial inspirado em Sonic the Hedgehog — color themes e file icons. Projeto de fã, gratuito, sem afiliação à SEGA.",
  "version": "0.4.0",
  "publisher": "AndreLuizJPoles",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreLuizJPoles/SonicTheme.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "sonic",
    "sonic-inspired",
    "fan-theme",
    "theme",
    "color-theme",
    "icon-theme",
    "dark",
    "light"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Sonic-Inspired Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/sonic-dark-color-theme.json"
      },
      {
        "label": "Sonic-Inspired Light",
        "uiTheme": "vs",
        "path": "./themes/sonic-light-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "sonic-inspired-icons",
        "label": "Sonic-Inspired Icons",
        "path": "./icons/sonic-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "icons:transparent": "node scripts/make-icons-transparent.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "sharp": "^0.33.5"
  }
}
